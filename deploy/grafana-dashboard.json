{
  "title": "FireDrill — Recovery Posture",
  "uid": "firedrill",
  "tags": ["firedrill", "backup", "disaster-recovery"],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "drill",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(firedrill_drill_verified, drill)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Recovery verified",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "min(firedrill_drill_verified{drill=~\"$drill\"})", "legendFormat": "verified" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "FAILED", "color": "red" }, "1": { "text": "VERIFIED", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "type": "stat",
      "title": "Measured RTO (latest)",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "max(firedrill_restore_duration_seconds{drill=~\"$drill\"})", "legendFormat": "RTO" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Backup age / RPO (latest)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "max(firedrill_backup_age_seconds{drill=~\"$drill\"})", "legendFormat": "backup age" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "stat",
      "title": "Time since last drill",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "time() - max(firedrill_drill_timestamp_seconds{drill=~\"$drill\"})", "legendFormat": "since last drill" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 93600 }, { "color": "red", "value": 180000 }] }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Measured RTO trend (alert on regression)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "firedrill_restore_duration_seconds{drill=~\"$drill\"}", "legendFormat": "{{drill}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Backup age at drill time (RPO trend)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "firedrill_backup_age_seconds{drill=~\"$drill\"}", "legendFormat": "{{drill}}" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "state-timeline",
      "title": "Drill verification history",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [{ "expr": "firedrill_drill_verified{drill=~\"$drill\"}", "legendFormat": "{{drill}}" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "failed", "color": "red" }, "1": { "text": "verified", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "table",
      "title": "Check results (latest)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [{ "expr": "firedrill_check_passed{drill=~\"$drill\"}", "format": "table", "instant": true }]
    }
  ]
}
